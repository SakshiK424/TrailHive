# =============================================
# TrailHive Environment Variables
# Rename this file to  .env  before running
# =============================================

# MongoDB — OPTION 1: Local (install MongoDB on your PC)
MONGO_URI=mongodb://127.0.0.1:27017/trailhive

# MongoDB — OPTION 2: Atlas cloud (free, recommended if local fails)
# MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/trailhive

# Server port
PORT=3000

